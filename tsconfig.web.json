{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "**/*.d.ts",
    "src/render/**/*.vue",
    "src/render/**/*.ts",
    "**/*.ts",
    "vite.config.mts",
  ],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "types": [
      "vite/client",
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router",
    ],
    "composite": true,
    "baseUrl": "./",
    "skipLibCheck": true,
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-typed-router",
      "vue-router/volar/sfc-route-blocks",
    ],
  },
  "exclude": [
    "**/dist",
    "**/build",
    ".vscode",
    "**/.git",
    "**/build",
    "cache",
    "**/.vite/",
    "**/node_modules"
  ],
}