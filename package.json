{
  "name": "fast-vite-nestjs-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@10.29.3",
  "description": "Vite + Electron + NestJS template powered by Electron Forge",
  "author": "calmripple",
  "main": ".vite/build/index.js",
  "scripts": {
    "gen:ipc-types": "tsx scripts/generate-ipc-types.ts",
    "gen:preload-api": "tsx scripts/generate-preload-api.ts",
    "gen:ipc": "pnpm gen:ipc-types && pnpm gen:preload-api",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "pnpm gen:ipc && electron-forge make",
    "package:insecure": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 pnpm run package",
    "make:insecure": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 pnpm run make",
    "build": "pnpm run make",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks || echo simple-git-hooks skipped && node -e \"try{const path=require('node:path');const cp=require('node:child_process');const pkg=require.resolve('electron-winstaller/package.json');const dir=path.dirname(pkg);cp.execFileSync(process.execPath,[path.join(dir,'script','select-7z-arch.js')],{cwd:dir,stdio:'inherit'});}catch(e){console.warn('electron-winstaller 7z setup skipped:',e&&e.message?e.message:e);}\""
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.11",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/microservices": "^11.1.16",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "element-plus": "^2.13.5",
    "es-object-atoms": "^1.1.1",
    "gopd": "^1.2.0",
    "math-intrinsics": "^1.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/fuses": "^2.1.0",
    "@lightwing/eslint-config": "^1.0.148",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/compiler-sfc": "3.5.30",
    "cross-env": "^10.1.0",
    "electron": "40.8.0",
    "eslint": "10.0.3",
    "lint-staged": "16.3.2",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "7.3.1",
    "vue-router": "^5.0.3",
    "vue-tsc": "3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "@nestjs/core",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "simple-git-hooks",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}