{
  "name": "fast-vite-nestjs-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@10.29.3",
  "description": "Vite + Electron with Doubleshot, so fast! ⚡",
  "author": "calmripple",
  "main": "dist/main/index.js",
  "scripts": {
    "gen:ipc-types": "tsx scripts/generate-ipc-types.ts",
    "gen:preload-api": "node scripts/generate-preload-api.mjs",
    "gen:ipc": "pnpm gen:ipc-types && pnpm gen:preload-api",
    "dev": "rimraf dist && pnpm gen:ipc && vite",
    "debug": "rimraf dist && pnpm gen:ipc && vite -- --dsb-debug",
    "build": "rimraf dist && pnpm gen:ipc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks && electron-builder install-app-deps"
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.11",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/microservices": "^11.1.14",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "element-plus": "^2.13.3",
    "i18next": "^25.8.13",
    "i18next-vue": "^1.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.0",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.29",
    "vue-i18n": "^9.14.5",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@lightwing/eslint-config": "^1.0.147",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/compiler-sfc": "3.5.28",
    "electron": "40.4.0",
    "electron-builder": "26.7.0",
    "eslint": "10.0.0",
    "lint-staged": "16.2.7",
    "rimraf": "6.1.2",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "7.3.1",
    "vite-plugin-doubleshot": "0.0.20",
    "vue-router": "^5.0.3",
    "vue-tsc": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "electron",
      "esbuild",
      "simple-git-hooks",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}