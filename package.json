{
  "name": "fast-vite-nestjs-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@10.29.3",
  "description": "Vite + Electron with Doubleshot, so fast! ⚡",
  "author": "calmripple",
  "main": "dist/main/index.js",
  "scripts": {
    "gen:ipc-types": "tsx scripts/generate-ipc-types.ts",
    "gen:preload-api": "tsx scripts/generate-preload-api.ts",
    "gen:ipc": "pnpm gen:ipc-types && pnpm gen:preload-api",
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.11",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/microservices": "^11.1.16",
    "axios": "^1.13.6",
    "call-bind-apply-helpers": "^1.0.2",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.13.5",
    "es-define-property": "^1.0.1",
    "es-object-atoms": "^1.1.1",
    "function-bind": "^1.1.2",
    "get-proto": "^1.0.1",
    "gopd": "^1.2.0",
    "math-intrinsics": "^1.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/compiler-sfc": "3.5.30",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "rimraf": "6.1.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "7.3.1",
    "vite-plugin-doubleshot": "0.0.20",
    "vue-router": "^5.0.3",
    "vue-tsc": "3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "@nestjs/core",
      "electron",
      "esbuild",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  }
}