{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "**/*.d.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "**/*.ts",
    "**/*.mts",
  ],
  "compilerOptions": {
    "composite": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
  },
  "exclude": [
    "./src/render",
  ],
}